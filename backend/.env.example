PORT=5000
MONGO_URI=mongodb://localhost:27017/gullyscore
NODE_ENV=development
# Comma-separated list of allowed origins, or "*" for all.
# In production set this to your frontend URL, e.g.
# CORS_ORIGIN=https://gullyscore-frontend.onrender.com
CORS_ORIGIN=*

# OWNER-ONLY KEY for destructive actions (delete team / remove player /
# delete roster player / delete match). Pick a long, hard-to-guess string
# and keep it to yourself. Leave unset to disable the lock (anyone can
# delete — the old default, useful only for local dev).
# ADMIN_TOKEN=replace-with-a-long-random-string
